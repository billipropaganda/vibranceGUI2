<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <FontFamily x:Key="Font.UI">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
  <FontFamily x:Key="Font.Display">Segoe UI Variable Display, Segoe UI Semibold, sans-serif</FontFamily>
  <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas, monospace</FontFamily>

  <sys:Double x:Key="Size.Caption">11</sys:Double>
  <sys:Double x:Key="Size.Label">12</sys:Double>
  <sys:Double x:Key="Size.Body">13</sys:Double>
  <sys:Double x:Key="Size.BodyLg">14</sys:Double>
  <sys:Double x:Key="Size.Title">16</sys:Double>
  <sys:Double x:Key="Size.Heading">20</sys:Double>
</ResourceDictionary>
