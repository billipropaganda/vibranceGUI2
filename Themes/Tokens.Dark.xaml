<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Surfaces -->
  <SolidColorBrush x:Key="Brush.Canvas"        Color="#0E0F13"/>
  <SolidColorBrush x:Key="Brush.Surface"       Color="#181A20"/>
  <SolidColorBrush x:Key="Brush.SurfaceAlt"    Color="#1F222A"/>
  <SolidColorBrush x:Key="Brush.SurfaceHover"  Color="#262A33"/>

  <!-- Borders -->
  <SolidColorBrush x:Key="Brush.Border"        Color="#2A2E38"/>
  <SolidColorBrush x:Key="Brush.BorderStrong"  Color="#3A404C"/>

  <!-- Text -->
  <SolidColorBrush x:Key="Brush.TextPrimary"   Color="#F3F5F9"/>
  <SolidColorBrush x:Key="Brush.TextSecondary" Color="#A4ABB8"/>
  <SolidColorBrush x:Key="Brush.TextMuted"     Color="#6B7280"/>

  <!-- Accent -->
  <SolidColorBrush x:Key="Brush.Accent"        Color="#6E7BFF"/>
  <SolidColorBrush x:Key="Brush.AccentHover"   Color="#828DFF"/>
  <SolidColorBrush x:Key="Brush.AccentPressed" Color="#5A66E8"/>
  <SolidColorBrush x:Key="Brush.AccentSubtle"  Color="#222540"/>
  <SolidColorBrush x:Key="Brush.OnAccent"      Color="#FFFFFF"/>

  <!-- Semantic -->
  <SolidColorBrush x:Key="Brush.Success"       Color="#36D399"/>
  <SolidColorBrush x:Key="Brush.Warning"       Color="#FBBF24"/>
  <SolidColorBrush x:Key="Brush.Error"         Color="#F87171"/>

  <!-- Slider track (unfilled) -->
  <SolidColorBrush x:Key="Brush.TrackInactive" Color="#30343F"/>
</ResourceDictionary>
