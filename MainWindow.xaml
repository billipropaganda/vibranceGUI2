<Window x:Class="vibranceGUI2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="vibranceGUI2" Height="740" Width="820"
        MinHeight="640" MinWidth="720"
        ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        Closing="Window_Closing" Loaded="Window_Loaded"
        StateChanged="Window_StateChanged"
        Background="{DynamicResource Brush.Canvas}"
        Foreground="{DynamicResource Brush.TextPrimary}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="vibranceGUI2" FontFamily="{StaticResource Font.Display}"
                           FontSize="{StaticResource Size.Heading}" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                <TextBlock Text="Per-app color profiles for any game or application"
                           FontSize="{StaticResource Size.Caption}"
                           Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource IconButton}"
                    Width="36" Height="36"
                    Click="SettingsBtn_Click" ToolTip="Settings">
                <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="16" Foreground="{DynamicResource Brush.TextSecondary}"/>
            </Button>
        </Grid>

        <!-- ═══ Default profile card ═══ -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Desktop (default)" FontWeight="SemiBold"
                               FontSize="{StaticResource Size.BodyLg}"
                               Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Reset"
                            Width="48" Height="24" FontSize="11" Padding="0"
                            Cursor="Hand" Click="ResetDefault_Click"
                            ToolTip="Reset all to default values">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="{DynamicResource Brush.SurfaceAlt}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource Brush.AccentSubtle}"/>
                                        <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="68"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Vibrance" VerticalAlignment="Center" FontSize="{StaticResource Size.Label}"/>
                    <Slider x:Name="DefaultVibrance" Grid.Column="1" Minimum="0" Maximum="100" Value="50"
                            Style="{StaticResource ModernSlider}" ValueChanged="DefaultSlider_ValueChanged"/>
                    <TextBox x:Name="DefaultVibranceText" Grid.Column="3"
                             Style="{StaticResource ValueField}" Text="50%"
                             TextAlignment="Center" LostFocus="TextBox_LostFocus"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="68"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Brightness" VerticalAlignment="Center" FontSize="{StaticResource Size.Label}"/>
                    <Slider x:Name="DefaultBrightness" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"
                            Style="{StaticResource ModernSlider}" ValueChanged="DefaultSlider_ValueChanged"/>
                    <TextBox x:Name="DefaultBrightnessText" Grid.Column="3"
                             Style="{StaticResource ValueField}" Text="50%"
                             TextAlignment="Center" LostFocus="TextBox_LostFocus"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="68"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Contrast" VerticalAlignment="Center" FontSize="{StaticResource Size.Label}"/>
                    <Slider x:Name="DefaultContrast" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"
                            Style="{StaticResource ModernSlider}" ValueChanged="DefaultSlider_ValueChanged"/>
                    <TextBox x:Name="DefaultContrastText" Grid.Column="3"
                             Style="{StaticResource ValueField}" Text="50%"
                             TextAlignment="Center" LostFocus="TextBox_LostFocus"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="68"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Gamma" VerticalAlignment="Center" FontSize="{StaticResource Size.Label}"/>
                    <Slider x:Name="DefaultGamma" Grid.Column="1" Minimum="0.5" Maximum="3.5" Value="1.0"
                            Style="{StaticResource ModernSlider}" ValueChanged="DefaultSlider_ValueChanged"/>
                    <TextBox x:Name="DefaultGammaText" Grid.Column="3"
                             Style="{StaticResource ValueField}" Text="1.00"
                             TextAlignment="Center" LostFocus="TextBox_LostFocus"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ═══ App profiles section header ═══ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Applications" FontSize="{StaticResource Size.Title}"
                           FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                <TextBlock x:Name="ProfileCountBadge" VerticalAlignment="Center" Margin="8,0,0,0"
                           FontSize="{StaticResource Size.Caption}"
                           FontFamily="{StaticResource Font.Mono}"
                           Foreground="{DynamicResource Brush.TextSecondary}"/>
            </StackPanel>
            <Button Grid.Column="2" Content="+ Add Application"
                    Style="{StaticResource PrimaryButton}" Click="AddApp_Click"/>
        </Grid>

        <!-- ═══ Profile card grid ═══ -->
        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <ItemsControl x:Name="ProfileCards">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Width="370" Margin="0,0,12,12"
                                    Cursor="Hand" MouseLeftButtonDown="Card_Edit"
                                    MouseRightButtonDown="Card_RightClick"
                                    Tag="{Binding .}">
                                <StackPanel>
                                    <!-- Header row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Width="24" Height="24"
                                               Margin="0,0,10,0" Source="{Binding Icon}"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProcessName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="{StaticResource Size.BodyLg}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.TextPrimary}"/>
                                            <TextBlock Text="{Binding FilePath}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding FilePath}"
                                                       FontSize="{StaticResource Size.Caption}"
                                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Style="{StaticResource IconButton}" Width="28" Height="28"
                                                    ToolTip="Edit" Tag="{Binding .}" Click="Card_EditBtn">
                                                <TextBlock Text="&#xE70F;"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource Brush.TextSecondary}"/>
                                            </Button>
                                            <Button Style="{StaticResource IconButton}" Width="28" Height="28"
                                                    ToolTip="Remove" Tag="{Binding .}" Click="Card_RemoveBtn">
                                                <TextBlock Text="&#xE74D;"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource Brush.Error}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Stat chips -->
                                    <UniformGrid Columns="4" Margin="0,12,0,0">
                                        <Border Background="{DynamicResource Brush.AccentSubtle}"
                                                CornerRadius="8" Padding="8,6" Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="VIB" FontSize="10"
                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                                <TextBlock Text="{Binding Vibrance, StringFormat={}{0}%}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="{StaticResource Size.Label}"
                                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource Brush.SurfaceAlt}"
                                                CornerRadius="8" Padding="8,6" Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="BRT" FontSize="10"
                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                                <TextBlock Text="{Binding Brightness, StringFormat=P0}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="{StaticResource Size.Label}"
                                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource Brush.SurfaceAlt}"
                                                CornerRadius="8" Padding="8,6" Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="CON" FontSize="10"
                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                                <TextBlock Text="{Binding Contrast, StringFormat=P0}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="{StaticResource Size.Label}"
                                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource Brush.SurfaceAlt}"
                                                CornerRadius="8" Padding="8,6" Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="GAM" FontSize="10"
                                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                                                <TextBlock Text="{Binding Gamma, StringFormat=F2}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="{StaticResource Size.Label}"
                                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <Border x:Name="EmptyState" BorderBrush="{DynamicResource Brush.BorderStrong}"
                        BorderThickness="2" CornerRadius="{StaticResource Radius.Card}"
                        Background="Transparent" Padding="40" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Margin="0,40,0,0">
                    <StackPanel HorizontalAlignment="Center" TextBlock.TextAlignment="Center">
                        <TextBlock Text="&#xE7B7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="32" Foreground="{DynamicResource Brush.TextMuted}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="No applications yet" FontSize="{StaticResource Size.BodyLg}"
                                   FontWeight="SemiBold" Margin="0,12,0,4"
                                   Foreground="{DynamicResource Brush.TextPrimary}"/>
                        <TextBlock Text="Add an app to give it its own color profile"
                                   FontSize="{StaticResource Size.Body}"
                                   Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,16"/>
                        <Button Content="+ Add Application" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Center" Click="AddApp_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
